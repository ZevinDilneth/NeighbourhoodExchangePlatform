# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get a public token at https://account.mapbox.com/access-tokens
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# ─── Google Maps (optional, used as fallback) ─────────────────────────────────
# Get an API key at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Daily.co (video meetings) ────────────────────────────────────────────────
# Your Daily.co subdomain (e.g. your-app.daily.co)
VITE_DAILY_DOMAIN=your-subdomain.daily.co
