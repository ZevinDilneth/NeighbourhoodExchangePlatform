# ─── Copy this file to .env and fill in all values ───────────────────────────

# ── Domain & ports ────────────────────────────────────────────────────────────
# Public hostname for Jitsi (e.g. meet.yourneighbourhood.com or localhost)
JITSI_DOMAIN=localhost
XMPP_DOMAIN=meet.jitsi
HTTPS_PORT=8443
HTTP_PORT=8080

# UDP port for video traffic — must be open in firewall
JVB_PORT=10000

# Your Docker host's public IP (needed for JVB to report correct address to clients)
DOCKER_HOST_ADDRESS=127.0.0.1

# ── JWT authentication ────────────────────────────────────────────────────────
# Must match JITSI_APP_ID and JITSI_JWT_SECRET in your main server/.env
JITSI_APP_ID=neighbourhood-exchange
JITSI_JWT_SECRET=CHANGE_ME_to_a_long_random_secret_at_least_32_chars

# ── Internal service passwords (generate with: openssl rand -hex 16) ─────────
JICOFO_AUTH_PASSWORD=CHANGE_ME_jicofo
JICOFO_COMPONENT_SECRET=CHANGE_ME_component
JVB_AUTH_PASSWORD=CHANGE_ME_jvb
JIBRI_XMPP_PASSWORD=CHANGE_ME_jibri_xmpp
JIBRI_RECORDER_PASSWORD=CHANGE_ME_jibri_recorder

# ── Recording ─────────────────────────────────────────────────────────────────
# Host directory where recordings & chat exports will be saved
RECORDINGS_DIR=./recordings
RECORDING_RESOLUTION=1920x1080

# Secret that finalize.sh uses when calling back to your Express server
FINALIZE_WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# URL of your Express server reachable FROM inside Docker
SERVER_URL=http://host.docker.internal:5000

# ── Guests & lobby ────────────────────────────────────────────────────────────
# 0 = all participants must have a JWT (most secure)
# 1 = participants without JWT join as guests (need moderator to admit)
ENABLE_GUESTS=0

# ── Config & data paths ───────────────────────────────────────────────────────
CONFIG=./config

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
