# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
TUNNEL_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/neighbourhood_exchange?appName=<cluster>

# ─── Redis ────────────────────────────────────────────────────────────────────
# Free tier at https://redis.io/try-free or https://redislabs.com
REDIS_URL=redis://default:<password>@<host>:<port>

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Get a token at https://account.mapbox.com/access-tokens
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Create an IAM user with S3 permissions at https://console.aws.amazon.com
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your-s3-bucket-name

# ─── Gmail SMTP (Nodemailer) ──────────────────────────────────────────────────
# Use a Gmail App Password (NOT your account password)
# Enable 2-Step Verification, then create one at: https://myaccount.google.com/apppasswords
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ─── Twilio (SMS / phone verification) ────────────────────────────────────────
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Daily.co (video meetings) ────────────────────────────────────────────────
# Get your API key at https://dashboard.daily.co/developers
DAILY_API_KEY=your_daily_api_key
DAILY_WEBHOOK_SECRET=your_daily_webhook_secret
RECORDINGS_BASE_DIR=./recordings

# ─── Dev helpers ──────────────────────────────────────────────────────────────
# Set to true to echo OTP codes in API responses (development only!)
DEV_SHOW_CODES=false
